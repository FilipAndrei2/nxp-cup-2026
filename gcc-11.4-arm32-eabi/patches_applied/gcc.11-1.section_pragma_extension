diff -ruN gcc-9.5.0-orig/gcc/varasm.c gcc-9.5.0/gcc/varasm.c
--- gcc-9.5.0-orig/gcc/varasm.c	2022-08-25 13:28:05.758424832 -0700
+++ gcc-9.5.0/gcc/varasm.c	2022-08-25 12:40:08.183241237 -0700
@@ -495,16 +495,29 @@
 
 #endif
 
+static inline tree ultimate_transparent_alias_target (tree *alias);
+
 section *
 get_context_text (tree decl, section *sec)
 {
   char section_name[256];
+  const char *name;
+  tree id;
+
   if (TREE_CODE(decl) == FUNCTION_DECL
       && decl->base.context_section_text)
     {
       section_name[0] = '\0';
       strcat (section_name, "\t.section\t");
       strcat (section_name, decl->base.context_section_text);
+      if (flag_function_sections) {
+	id = DECL_ASSEMBLER_NAME (decl);
+	ultimate_transparent_alias_target (&id);
+	name = IDENTIFIER_POINTER (id);
+	name = targetm.strip_name_encoding (name);
+	strcat (section_name, ".");
+	strcat (section_name, name);
+      }
       strcat (section_name, ",\"ax\",%progbits");
       return get_unnamed_section (SECTION_CODE, output_section_asm_op, ggc_strdup(section_name));
     }
